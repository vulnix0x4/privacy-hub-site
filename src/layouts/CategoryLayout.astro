---
/**
 * CategoryLayout — tool category page chrome.
 *
 * Hero shows title, framing, optional affiliate disclosure (FTC 16 CFR Part
 * 255 — design doc §8.3 rule 2). "Hero pick" callout, "Alternatives" list,
 * and "Related vectors" cross-link block round out the page frame; the MDX
 * body slots in between hero and the picks. Difficulty tag rendered when
 * the entry declares one.
 */
import type { CollectionEntry } from 'astro:content';
import Layout from './Layout.astro';
import { buildArticleJsonLd, buildBreadcrumbJsonLd } from '../lib/seo/jsonLd';

interface Props {
  entry: CollectionEntry<'categories'>;
}

const { entry } = Astro.props;
const { data } = entry;

const lastVerified = data.last_verified.toISOString().slice(0, 10);

const canonicalPath = `/en/categories/${entry.id}`;
const ogImage = `/og/categories--${entry.id}.png`;
const articleLd = buildArticleJsonLd({
  title: data.title,
  description: data.description,
  lastVerified: data.last_verified,
  canonicalUrl: canonicalPath,
});
const breadcrumbLd = buildBreadcrumbJsonLd([
  { name: 'Home', url: '/en/' },
  { name: 'Categories', url: '/en/categories' },
  { name: data.title, url: canonicalPath },
]);

const difficultyLabel: Record<string, { glyph: string; label: string }> = {
  easy: { glyph: '🟢', label: 'Easy — no install' },
  intermediate: { glyph: '🟡', label: 'Intermediate — install or configure' },
  advanced: { glyph: '🔴', label: 'Advanced — self-host or threat-model sensitive' },
};

const affiliateCopy: Record<typeof data.affiliate, string | null> = {
  proton: 'We earn a commission if you sign up via this link.',
  'privacy-com': 'We earn a commission if you sign up via this link.',
  smspool: 'We earn a commission if you sign up via this link.',
  bitwarden: 'We earn a commission if you sign up via this link.',
  brave: 'We earn a commission if you sign up via this link.',
  kagi: 'We earn a commission if you sign up via this link.',
  obsidian: 'We earn a commission if you sign up via this link.',
  ente: 'We earn a commission if you sign up via this link.',
  none: null,
};

const affiliateNote = affiliateCopy[data.affiliate];
const categoryDifficulty = data.difficulty ? difficultyLabel[data.difficulty] : null;
---
<Layout title={`${data.title} — privacy.whattheflip.lol`} description={data.description} ogImage={ogImage}>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(articleLd)} is:inline></script>
    <script type="application/ld+json" set:html={JSON.stringify(breadcrumbLd)} is:inline></script>
  </Fragment>
  <article class="max-w-3xl py-6 space-y-8">
    <nav aria-label="Breadcrumb" class="text-sm text-text-muted">
      <a href="/en/categories" class="hover:text-text">Categories</a>
      <span aria-hidden="true" class="px-2">/</span>
      <span class="text-text">{data.title}</span>
    </nav>

    <header class="space-y-4">
      <h1 class="text-3xl font-semibold tracking-tight text-text sm:text-4xl">{data.title}</h1>
      <p class="text-lg text-text-muted">{data.description}</p>
      {categoryDifficulty && (
        <p class="inline-flex items-center gap-2 rounded-full border border-white/10 bg-surface px-3 py-1 text-sm text-text-muted">
          <span aria-hidden="true">{categoryDifficulty.glyph}</span>
          <span>{categoryDifficulty.label}</span>
        </p>
      )}
      {affiliateNote && (
        <aside
          role="note"
          aria-label="Affiliate disclosure"
          class="rounded border border-accent/30 bg-accent/5 px-4 py-3 text-sm text-text"
        >
          <strong class="font-semibold">Affiliate disclosure:</strong> {affiliateNote} You can pick a
          non-affiliate alternative below — every category lists at least one.
        </aside>
      )}
    </header>

    <div class="prose-zinc prose-invert max-w-none space-y-4 text-text leading-relaxed">
      <slot />
    </div>

    <section aria-labelledby="category-hero-pick" class="rounded-lg border border-accent/30 bg-surface p-5">
      <h2 id="category-hero-pick" class="text-sm font-semibold uppercase tracking-wider text-accent">
        This just works
      </h2>
      <p class="mt-2 text-lg font-semibold text-text">{data.hero_pick}</p>
      <p class="mt-1 text-sm text-text-muted">
        Our top opinionated pick. Read the body above for why we chose this one.
      </p>
    </section>

    <section aria-labelledby="category-alternatives" class="space-y-3">
      <h2 id="category-alternatives" class="text-sm font-semibold uppercase tracking-wider text-text-muted">
        Alternatives
      </h2>
      <ul class="grid gap-2 sm:grid-cols-2">
        {data.alternatives.map((alt) => (
          <li class="rounded border border-white/10 bg-surface px-3 py-2 text-sm text-text">{alt}</li>
        ))}
      </ul>
    </section>

    {data.related.length > 0 && (
      <section aria-labelledby="category-related-vectors" class="border-t border-white/10 pt-6">
        <h2 id="category-related-vectors" class="text-sm font-semibold uppercase tracking-wider text-text-muted">
          Related vectors
        </h2>
        <ul class="mt-3 grid gap-2 sm:grid-cols-2">
          {data.related.map((slug) => (
            <li>
              <a
                href={`/en/vectors/${slug}`}
                class="block rounded border border-white/10 bg-surface px-3 py-2 text-sm text-text hover:border-accent/50 hover:text-accent"
              >
                {slug}
              </a>
            </li>
          ))}
        </ul>
      </section>
    )}

    <p class="border-t border-white/10 pt-4 text-sm text-text-muted">
      Last verified <time datetime={lastVerified}>{lastVerified}</time>
    </p>
  </article>
</Layout>
