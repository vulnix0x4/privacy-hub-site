---
/**
 * BasicsLayout — short essay layout for foundation pages.
 *
 * Minimal chrome by design: hero with title + description, MDX body, and
 * the locked `last_verified` line. Basics pages are short — anything
 * heavier belongs in /guides or /vectors.
 */
import type { CollectionEntry } from 'astro:content';
import Layout from './Layout.astro';
import { buildArticleJsonLd, buildBreadcrumbJsonLd } from '../lib/seo/jsonLd';

interface Props {
  entry: CollectionEntry<'basics'>;
}

const { entry } = Astro.props;
const { data } = entry;

const lastVerified = data.last_verified.toISOString().slice(0, 10);

const canonicalPath = `/en/basics/${entry.id}`;
const articleLd = buildArticleJsonLd({
  title: data.title,
  description: data.description,
  lastVerified: data.last_verified,
  canonicalUrl: canonicalPath,
});
const breadcrumbLd = buildBreadcrumbJsonLd([
  { name: 'Home', url: '/en/' },
  { name: 'Basics', url: '/en/basics' },
  { name: data.title, url: canonicalPath },
]);

const difficultyLabel: Record<string, { glyph: string; label: string }> = {
  easy: { glyph: '🟢', label: 'Easy' },
  intermediate: { glyph: '🟡', label: 'Intermediate' },
  advanced: { glyph: '🔴', label: 'Advanced' },
};

const basicsDifficulty = data.difficulty ? difficultyLabel[data.difficulty] : null;
---
<Layout title={`${data.title} — privacy.whattheflip.lol`} description={data.description}>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(articleLd)} is:inline></script>
    <script type="application/ld+json" set:html={JSON.stringify(breadcrumbLd)} is:inline></script>
  </Fragment>
  <article class="max-w-3xl py-6 space-y-8">
    <nav aria-label="Breadcrumb" class="text-sm text-text-muted">
      <a href="/en/basics" class="hover:text-text">Basics</a>
      <span aria-hidden="true" class="px-2">/</span>
      <span class="text-text">{data.title}</span>
    </nav>

    <header class="space-y-4">
      <h1 class="text-3xl font-semibold tracking-tight text-text sm:text-4xl">{data.title}</h1>
      <p class="text-lg text-text-muted">{data.description}</p>
      {basicsDifficulty && (
        <p class="inline-flex items-center gap-2 rounded-full border border-white/10 bg-surface px-3 py-1 text-sm text-text-muted">
          <span aria-hidden="true">{basicsDifficulty.glyph}</span>
          <span>{basicsDifficulty.label}</span>
        </p>
      )}
    </header>

    <div class="prose-zinc prose-invert max-w-none space-y-4 text-text leading-relaxed">
      <slot />
    </div>

    {data.related.length > 0 && (
      <section aria-labelledby="related" class="border-t border-white/10 pt-6">
        <h2 id="related" class="text-sm font-semibold uppercase tracking-wider text-text-muted">
          Related
        </h2>
        <ul class="mt-3 grid gap-2 sm:grid-cols-2">
          {data.related.map((slug) => (
            <li>
              <a
                href={`/en/basics/${slug}`}
                class="block rounded border border-white/10 bg-surface px-3 py-2 text-sm text-text hover:border-accent/50 hover:text-accent"
              >
                {slug}
              </a>
            </li>
          ))}
        </ul>
      </section>
    )}

    <p class="border-t border-white/10 pt-4 text-sm text-text-muted">
      Last verified <time datetime={lastVerified}>{lastVerified}</time>
    </p>
  </article>
</Layout>
