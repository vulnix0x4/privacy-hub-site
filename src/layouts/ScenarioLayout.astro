---
/**
 * ScenarioLayout — threat-model playlist chrome.
 *
 * The playlist is the load-bearing UI: it appears immediately under the
 * hero as an ordered list, each item linking to its target page (vector /
 * category / guide / basics). The MDX body sits below the playlist for
 * any framing or "what this won't protect you from" copy. Jurisdiction
 * note callout (design doc §9.2) renders above the playlist when set.
 */
import type { CollectionEntry } from 'astro:content';
import Layout from './Layout.astro';

interface Props {
  entry: CollectionEntry<'scenarios'>;
}

const { entry } = Astro.props;
const { data } = entry;

const lastVerified = data.last_verified.toISOString().slice(0, 10);

const playlistTypeBase: Record<string, string> = {
  basics: '/en/basics/',
  vector: '/en/vectors/',
  category: '/en/categories/',
  guide: '/en/guides/',
};

const difficultyLabel: Record<string, { glyph: string; label: string }> = {
  easy: { glyph: '🟢', label: 'Easy' },
  intermediate: { glyph: '🟡', label: 'Intermediate' },
  advanced: { glyph: '🔴', label: 'Advanced' },
};

const scenarioDifficulty = data.difficulty ? difficultyLabel[data.difficulty] : null;
---
<Layout title={`${data.title} — privacy.whattheflip.lol`} description={data.description}>
  <article class="max-w-3xl py-6 space-y-8">
    <nav aria-label="Breadcrumb" class="text-sm text-text-muted">
      <a href="/en/scenarios" class="hover:text-text">Scenarios</a>
      <span aria-hidden="true" class="px-2">/</span>
      <span class="text-text">{data.title}</span>
    </nav>

    <header class="space-y-4">
      <h1 class="text-3xl font-semibold tracking-tight text-text sm:text-4xl">{data.title}</h1>
      <p class="text-lg text-text-muted">{data.description}</p>
      {scenarioDifficulty && (
        <p class="inline-flex items-center gap-2 rounded-full border border-white/10 bg-surface px-3 py-1 text-sm text-text-muted">
          <span aria-hidden="true">{scenarioDifficulty.glyph}</span>
          <span>{scenarioDifficulty.label}</span>
        </p>
      )}
    </header>

    {data.jurisdiction_note && (
      <aside
        role="note"
        aria-label="Jurisdiction note"
        class="rounded border border-state-unchanged/30 bg-state-unchanged/5 px-4 py-3 text-sm text-text"
      >
        <strong class="font-semibold">Jurisdiction note:</strong> {data.jurisdiction_note}
      </aside>
    )}

    <section aria-labelledby="playlist" class="space-y-3">
      <h2 id="playlist" class="text-sm font-semibold uppercase tracking-wider text-text-muted">
        Your playlist
      </h2>
      <ol class="space-y-3">
        {data.playlist.map((item, index) => {
          const href = `${playlistTypeBase[item.type] ?? '/en/'}${item.slug}`;
          return (
            <li class="rounded border border-white/10 bg-surface p-4">
              <a href={href} class="block group">
                <div class="flex items-start gap-3">
                  <span
                    aria-hidden="true"
                    class="shrink-0 rounded-full border border-white/10 bg-bg px-2.5 py-0.5 text-xs font-mono text-text-muted"
                  >
                    {index + 1}
                  </span>
                  <div class="min-w-0 flex-1 space-y-1">
                    <p class="font-medium text-text group-hover:text-accent">
                      {item.slug}
                      <span class="ml-2 text-xs uppercase tracking-wider text-text-muted">{item.type}</span>
                    </p>
                    <p class="text-sm text-text-muted">{item.why}</p>
                  </div>
                </div>
              </a>
            </li>
          );
        })}
      </ol>
    </section>

    <div class="prose-zinc prose-invert max-w-none space-y-4 text-text leading-relaxed">
      <slot />
    </div>

    {data.related.length > 0 && (
      <section aria-labelledby="related-vectors" class="border-t border-white/10 pt-6">
        <h2 id="related-vectors" class="text-sm font-semibold uppercase tracking-wider text-text-muted">
          Related scenarios &amp; vectors
        </h2>
        <ul class="mt-3 grid gap-2 sm:grid-cols-2">
          {data.related.map((slug) => (
            <li>
              <a
                href={`/en/scenarios/${slug}`}
                class="block rounded border border-white/10 bg-surface px-3 py-2 text-sm text-text hover:border-accent/50 hover:text-accent"
              >
                {slug}
              </a>
            </li>
          ))}
        </ul>
      </section>
    )}

    <p class="border-t border-white/10 pt-4 text-sm text-text-muted">
      Last verified <time datetime={lastVerified}>{lastVerified}</time>
    </p>
  </article>
</Layout>
