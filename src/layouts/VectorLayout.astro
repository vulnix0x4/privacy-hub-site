---
/**
 * VectorLayout — encyclopedia entry chrome.
 *
 * Receives the resolved CollectionEntry<'vectors'> and the rendered MDX
 * `<Content />`. Hero shows family pill, severity + prevalence badges, and
 * the locked `last_verified` date. Body slots in below. "Related vectors"
 * cross-link block at the bottom (schema enforces ≥2 entries per design
 * doc §4.3).
 */
import type { CollectionEntry } from 'astro:content';
import Layout from './Layout.astro';
import { FAMILY_PILL_CLASS } from '../components/scanner/badgeConfig';
import { buildArticleJsonLd, buildBreadcrumbJsonLd } from '../lib/seo/jsonLd';

interface Props {
  entry: CollectionEntry<'vectors'>;
}

const { entry } = Astro.props;
const { data } = entry;

const canonicalPath = `/en/vectors/${entry.id}`;
const ogImage = `/og/vectors--${entry.id}.png`;
const articleLd = buildArticleJsonLd({
  title: data.title,
  description: data.description,
  lastVerified: data.last_verified,
  canonicalUrl: canonicalPath,
});
const breadcrumbLd = buildBreadcrumbJsonLd([
  { name: 'Home', url: '/en/' },
  { name: 'Vectors', url: '/en/vectors' },
  { name: data.title, url: canonicalPath },
]);

// Severity badge colours map to the design doc §14.1 state palette.
const severityClass: Record<typeof data.severity, string> = {
  critical: 'bg-state-unchanged/15 text-state-unchanged-text border-state-unchanged/40',
  high: 'bg-state-spoofed/15 text-state-spoofed-text border-state-spoofed/40',
  medium: 'bg-surface-raised text-text-muted border-white/10',
  low: 'bg-surface-raised text-text-muted border-white/10',
};

const prevalenceLabel: Record<typeof data.prevalence, string> = {
  'very-common': 'Very common',
  common: 'Common',
  rare: 'Rare',
};

const familyPill = FAMILY_PILL_CLASS[data.family] ?? '';
const lastVerified = data.last_verified.toISOString().slice(0, 10);
---
<Layout title={`${data.title} — privacy.whattheflip.lol`} description={data.description} ogImage={ogImage}>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(articleLd)} is:inline></script>
    <script type="application/ld+json" set:html={JSON.stringify(breadcrumbLd)} is:inline></script>
  </Fragment>
  <article class="max-w-3xl py-6 space-y-8">
    <nav aria-label="Breadcrumb" class="text-sm text-text-muted">
      <a href="/en/vectors" class="hover:text-text">Vectors</a>
      <span aria-hidden="true" class="px-2">/</span>
      <span class="text-text">{data.title}</span>
    </nav>

    <header class="space-y-4">
      <div class="flex flex-wrap items-center gap-2 text-xs">
        <span class={`inline-flex items-center rounded px-2 py-0.5 font-medium uppercase tracking-wider ${familyPill}`}>
          {data.family}
        </span>
        <span class={`inline-flex items-center rounded-full border px-2.5 py-0.5 font-medium ${severityClass[data.severity]}`}>
          {data.severity}
        </span>
        <span class="inline-flex items-center rounded-full border border-white/10 bg-surface-raised px-2.5 py-0.5 text-text-muted">
          {prevalenceLabel[data.prevalence]}
        </span>
        {!data.in_scanner && (
          <span class="inline-flex items-center rounded-full border border-white/10 bg-surface-raised px-2.5 py-0.5 text-text-muted">
            Not in scanner
          </span>
        )}
      </div>
      <h1 class="text-3xl font-semibold tracking-tight text-text sm:text-4xl">{data.title}</h1>
      <p class="text-lg text-text-muted">{data.description}</p>
    </header>

    <div class="prose-zinc prose-invert max-w-none space-y-4 text-text leading-relaxed">
      <slot />
    </div>

    {data.related.length > 0 && (
      <section aria-labelledby="related-vectors" class="border-t border-white/10 pt-6">
        <h2 id="related-vectors" class="text-sm font-semibold uppercase tracking-wider text-text-muted">
          Related vectors
        </h2>
        <ul class="mt-3 grid gap-2 sm:grid-cols-2">
          {data.related.map((slug) => (
            <li>
              <a
                href={`/en/vectors/${slug}`}
                class="block rounded border border-white/10 bg-surface px-3 py-2 text-sm text-text hover:border-accent/50 hover:text-accent"
              >
                {slug}
              </a>
            </li>
          ))}
        </ul>
      </section>
    )}

    <p class="border-t border-white/10 pt-4 text-sm text-text-muted">
      Last verified <time datetime={lastVerified}>{lastVerified}</time>
    </p>
  </article>
</Layout>
