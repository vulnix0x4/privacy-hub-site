---
/**
 * GuideLayout — step-by-step how-to chrome.
 *
 * Hero shows time estimate, difficulty tag, and prerequisites list (design
 * doc §10.1). Body slots in below for the WHAT-YOU'LL-END-UP-WITH /
 * STEPS / VERIFY-IT-WORKED / COMMON-PITFALLS sections that the MDX file
 * carries.
 */
import type { CollectionEntry } from 'astro:content';
import Layout from './Layout.astro';
import { buildBreadcrumbJsonLd, buildHowToJsonLd } from '../lib/seo/jsonLd';

interface Props {
  entry: CollectionEntry<'guides'>;
}

const { entry } = Astro.props;
const { data } = entry;

const lastVerified = data.last_verified.toISOString().slice(0, 10);

// HowTo JSON-LD. We emit the HowTo without a step array at the layout
// level — parsing the MDX body for H2/H3 steps here would require
// remark-level tooling that doesn't fit inside a layout component. The
// HowTo without steps still passes schema.org validation; the page body
// carries the human-readable step list.
const canonicalPath = `/en/guides/${entry.id}`;
const ogImage = `/og/guides--${entry.id}.png`;
const howToLd = buildHowToJsonLd({
  title: data.title,
  description: data.description,
  timeMinutes: data.time_minutes,
  lastVerified: data.last_verified,
  canonicalUrl: canonicalPath,
});
const breadcrumbLd = buildBreadcrumbJsonLd([
  { name: 'Home', url: '/en/' },
  { name: 'Guides', url: '/en/guides' },
  { name: data.title, url: canonicalPath },
]);

const difficultyLabel: Record<string, { glyph: string; label: string }> = {
  easy: { glyph: '🟢', label: 'Easy — no install' },
  intermediate: { glyph: '🟡', label: 'Intermediate — install or configure' },
  advanced: { glyph: '🔴', label: 'Advanced — self-host or threat-model sensitive' },
};

const difficulty = data.difficulty ? difficultyLabel[data.difficulty] : null;
---
<Layout title={`${data.title} — privacy.whattheflip.lol`} description={data.description} ogImage={ogImage}>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(howToLd)} is:inline></script>
    <script type="application/ld+json" set:html={JSON.stringify(breadcrumbLd)} is:inline></script>
  </Fragment>
  <article class="max-w-3xl py-6 space-y-8">
    <nav aria-label="Breadcrumb" class="text-sm text-text-muted">
      <a href="/en/guides" class="hover:text-text">Guides</a>
      <span aria-hidden="true" class="px-2">/</span>
      <span class="text-text">{data.title}</span>
    </nav>

    <header class="space-y-4">
      <h1 class="text-3xl font-semibold tracking-tight text-text sm:text-4xl">{data.title}</h1>
      <p class="text-lg text-text-muted">{data.description}</p>
      <div class="flex flex-wrap items-center gap-3 text-sm text-text-muted">
        <span class="inline-flex items-center gap-2 rounded-full border border-white/10 bg-surface px-3 py-1">
          <span aria-hidden="true">⏱</span>
          <span>~{data.time_minutes} min</span>
        </span>
        {difficulty && (
          <span class="inline-flex items-center gap-2 rounded-full border border-white/10 bg-surface px-3 py-1">
            <span aria-hidden="true">{difficulty.glyph}</span>
            <span>{difficulty.label}</span>
          </span>
        )}
      </div>
      {data.prerequisites.length > 0 && (
        <div class="rounded border border-white/10 bg-surface px-4 py-3">
          <p class="text-xs font-semibold uppercase tracking-wider text-text-muted">Prerequisites</p>
          <ul class="mt-2 list-disc space-y-1 pl-5 text-sm text-text">
            {data.prerequisites.map((p) => (
              <li>{p}</li>
            ))}
          </ul>
        </div>
      )}
    </header>

    <div class="prose-zinc prose-invert max-w-none space-y-4 text-text leading-relaxed">
      <slot />
    </div>

    {data.related.length > 0 && (
      <section aria-labelledby="related-guides" class="border-t border-white/10 pt-6">
        <h2 id="related-guides" class="text-sm font-semibold uppercase tracking-wider text-text-muted">
          Related
        </h2>
        <ul class="mt-3 grid gap-2 sm:grid-cols-2">
          {data.related.map((slug) => (
            <li>
              <a
                href={`/en/guides/${slug}`}
                class="block rounded border border-white/10 bg-surface px-3 py-2 text-sm text-text hover:border-accent/50 hover:text-accent"
              >
                {slug}
              </a>
            </li>
          ))}
        </ul>
      </section>
    )}

    <p class="border-t border-white/10 pt-4 text-sm text-text-muted">
      Last verified <time datetime={lastVerified}>{lastVerified}</time>
    </p>
  </article>
</Layout>
