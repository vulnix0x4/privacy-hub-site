---
/**
 * Tool-categories index. Alphabetical by title — no subgrouping yet
 * (design doc §8.2 lists them flat). Cards surface the affiliate flag
 * so the disclosure rule (§8.3 #2) is visible from the index.
 */
import { getCollection } from 'astro:content';
import Layout from '../../../layouts/Layout.astro';

export const prerender = true;

const entries = (await getCollection('categories')).sort((a, b) =>
  a.data.title.localeCompare(b.data.title),
);

const difficultyGlyph: Record<string, string> = {
  easy: '🟢',
  intermediate: '🟡',
  advanced: '🔴',
};
---
<Layout
  title="Tool categories — privacy.whattheflip.lol"
  description="Opinionated picks across every privacy tool category. Free first, affiliate disclosed inline, ranked by merit not commission."
>
  <div class="max-w-5xl py-6 space-y-10">
    <header class="space-y-3">
      <p class="text-sm uppercase tracking-wider text-text-muted">Categories</p>
      <h1 class="text-3xl font-semibold tracking-tight text-text sm:text-4xl">Tool categories</h1>
      <p class="max-w-2xl text-lg text-text-muted">
        Each category lists one opinionated <em>this just works</em> pick and at least one
        non-affiliate alternative. Affiliate relationships are disclosed inline and never
        affect ranking.
      </p>
    </header>

    <nav aria-label="Categories index">
      <ul class="grid gap-3 sm:grid-cols-2 lg:grid-cols-3">
        {entries.map((entry) => (
          <li>
            <a
              href={`/en/categories/${entry.id}`}
              class="block h-full rounded-lg border border-white/10 bg-surface p-4 transition-colors hover:border-accent/50"
            >
              <div class="flex items-center gap-2 text-xs">
                <span class="inline-flex items-center rounded-full border border-white/10 bg-surface-raised px-2 py-0.5 font-medium uppercase tracking-wider text-text-muted">
                  category
                </span>
                {entry.data.difficulty && difficultyGlyph[entry.data.difficulty] && (
                  <span class="text-text-muted" aria-label={`Difficulty: ${entry.data.difficulty}`}>
                    {difficultyGlyph[entry.data.difficulty]} {entry.data.difficulty}
                  </span>
                )}
                {entry.data.affiliate !== 'none' && (
                  <span
                    class="ml-auto inline-flex items-center rounded-full border border-accent/30 bg-accent/10 px-2 py-0.5 text-accent"
                    title="We earn a commission if you sign up via this category's pick"
                  >
                    affiliate
                  </span>
                )}
              </div>
              <h2 class="mt-2 text-base font-semibold text-text">{entry.data.title}</h2>
              <p class="mt-1 text-sm text-text-muted">{entry.data.description}</p>
            </a>
          </li>
        ))}
      </ul>
    </nav>
  </div>
</Layout>
