---
/**
 * Guides index — sorted by difficulty, then time. Easiest + fastest
 * surfaces first so a returning visitor scans the page as a cost-ranked
 * to-do list.
 */
import { getCollection } from 'astro:content';
import Layout from '../../../layouts/Layout.astro';

export const prerender = true;

const DIFFICULTY_RANK = { easy: 0, intermediate: 1, advanced: 2 } as const;

const entries = (await getCollection('guides')).sort((a, b) => {
  const ra = a.data.difficulty ? DIFFICULTY_RANK[a.data.difficulty] : 99;
  const rb = b.data.difficulty ? DIFFICULTY_RANK[b.data.difficulty] : 99;
  if (ra !== rb) return ra - rb;
  return a.data.time_minutes - b.data.time_minutes;
});

const difficultyGlyph: Record<string, string> = {
  easy: '🟢',
  intermediate: '🟡',
  advanced: '🔴',
};
---
<Layout
  title="Step-by-step guides — privacy.whattheflip.lol"
  description="One problem, one fix, one page. Each guide ships a verifiable end-state and a deep-link back to the scanner to confirm it worked."
>
  <div class="max-w-5xl py-6 space-y-10">
    <header class="space-y-3">
      <p class="text-sm uppercase tracking-wider text-text-muted">Guides</p>
      <h1 class="text-3xl font-semibold tracking-tight text-text sm:text-4xl">Step-by-step guides</h1>
      <p class="max-w-2xl text-lg text-text-muted">
        Each guide is one problem, one fix. Sorted easiest first — start anywhere and the
        compounding starts immediately.
      </p>
    </header>

    <nav aria-label="Guides index">
      <ul class="grid gap-3 sm:grid-cols-2 lg:grid-cols-3">
        {entries.map((entry) => (
          <li>
            <a
              href={`/en/guides/${entry.id}`}
              class="block h-full rounded-lg border border-white/10 bg-surface p-4 transition-colors hover:border-accent/50"
            >
              <div class="flex items-center gap-2 text-xs">
                <span class="inline-flex items-center rounded-full border border-white/10 bg-surface-raised px-2 py-0.5 font-medium uppercase tracking-wider text-text-muted">
                  guide
                </span>
                {entry.data.difficulty && difficultyGlyph[entry.data.difficulty] && (
                  <span class="text-text-muted" aria-label={`Difficulty: ${entry.data.difficulty}`}>
                    {difficultyGlyph[entry.data.difficulty]} {entry.data.difficulty}
                  </span>
                )}
                <span class="ml-auto text-text-muted">~{entry.data.time_minutes} min</span>
              </div>
              <h2 class="mt-2 text-base font-semibold text-text">{entry.data.title}</h2>
              <p class="mt-1 text-sm text-text-muted">{entry.data.description}</p>
            </a>
          </li>
        ))}
      </ul>
    </nav>
  </div>
</Layout>
