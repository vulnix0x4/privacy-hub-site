---
/**
 * Scenarios index — "I'm a [X]" cards.
 *
 * Sorted by difficulty (easy first) then alphabetical so the normie
 * onramp ("Just want privacy basics") sits at the top. Each card shows
 * the scenario title, one-line description, difficulty, and playlist
 * length so the visitor can pick the one that fits their threat model.
 */
import { getCollection } from 'astro:content';
import Layout from '../../../layouts/Layout.astro';

export const prerender = true;

const DIFFICULTY_RANK = { easy: 0, intermediate: 1, advanced: 2 } as const;

const entries = (await getCollection('scenarios')).sort((a, b) => {
  const ra = a.data.difficulty ? DIFFICULTY_RANK[a.data.difficulty] : 99;
  const rb = b.data.difficulty ? DIFFICULTY_RANK[b.data.difficulty] : 99;
  if (ra !== rb) return ra - rb;
  return a.data.title.localeCompare(b.data.title);
});

const difficultyGlyph: Record<string, string> = {
  easy: '🟢',
  intermediate: '🟡',
  advanced: '🔴',
};
---
<Layout
  title="Threat-model scenarios — privacy.whattheflip.lol"
  description="Pick your situation. Each scenario is a curated playlist of vectors, categories, and guides ordered by payoff per minute of work."
>
  <div class="max-w-5xl py-6 space-y-10">
    <header class="space-y-3">
      <p class="text-sm uppercase tracking-wider text-text-muted">Scenarios</p>
      <h1 class="text-3xl font-semibold tracking-tight text-text sm:text-4xl">Pick your scenario</h1>
      <p class="max-w-2xl text-lg text-text-muted">
        Different threat models, different priorities. Each scenario is a curated playlist of
        existing pages — no new content, just opinionated ordering and framing for your
        situation.
      </p>
    </header>

    <nav aria-label="Scenarios index">
      <ul class="grid gap-3 sm:grid-cols-2 lg:grid-cols-3">
        {entries.map((entry) => (
          <li>
            <a
              href={`/en/scenarios/${entry.id}`}
              class="block h-full rounded-lg border border-white/10 bg-surface p-4 transition-colors hover:border-accent/50"
            >
              <div class="flex items-center gap-2 text-xs">
                <span class="inline-flex items-center rounded-full border border-white/10 bg-surface-raised px-2 py-0.5 font-medium uppercase tracking-wider text-text-muted">
                  scenario
                </span>
                {entry.data.difficulty && difficultyGlyph[entry.data.difficulty] && (
                  <span class="text-text-muted" aria-label={`Difficulty: ${entry.data.difficulty}`}>
                    {difficultyGlyph[entry.data.difficulty]} {entry.data.difficulty}
                  </span>
                )}
                <span class="ml-auto text-text-muted">{entry.data.playlist.length} steps</span>
              </div>
              <h2 class="mt-2 text-base font-semibold text-text">I'm a {entry.data.title.toLowerCase()}</h2>
              <p class="mt-1 text-sm text-text-muted">{entry.data.description}</p>
            </a>
          </li>
        ))}
      </ul>
    </nav>
  </div>
</Layout>
