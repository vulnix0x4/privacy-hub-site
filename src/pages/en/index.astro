---
import Layout from '../../layouts/Layout.astro';
---
<Layout
  title="privacy.whattheflip.lol — the privacy hub"
  description="Opinionated privacy tools that just work. Live tracker scanner, full encyclopedia of tracking vectors, threat-model playlists, and step-by-step guides."
>
  <section class="max-w-3xl space-y-6 py-12">
    <h1 class="text-4xl sm:text-5xl font-semibold tracking-tight">Privacy hub — coming soon.</h1>
    <p class="text-lg text-text-muted">
      Live scanner. Full tracking-vector encyclopedia. Opinionated tool picks.
      No cookies, no analytics, no third-party scripts.
    </p>
    <p>
      <a
        href="/en/scan"
        class="inline-flex items-center gap-2 rounded-md border border-accent/40 bg-accent/10 px-4 py-2 text-base font-medium text-accent hover:bg-accent/20"
      >
        Try the live scanner &rarr;
      </a>
    </p>
    <p class="text-sm text-text-muted">
      Scaffolded <time datetime="2026-04-17">2026-04-17</time>. Follow build progress on
      <a class="underline" href="https://github.com/vulnix0x4/privacy-hub-site">GitHub</a>.
    </p>
  </section>
</Layout>
