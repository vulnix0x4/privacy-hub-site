# Copy to .env and adjust.

# Web server port (what your upstream Caddy reverse-proxies to)
WEB_PORT=8421

# Scanner backend (Phase 3+)
JA4_PORT=8443
DNS_PORT=5353

# Public URLs the scanner probes (client-side) and the backend (server-side) reference.
# PUBLIC_ prefix makes these visible to client JS via import.meta.env.
PUBLIC_SCAN_JA4_URL=https://ja4.scan.privacy.whattheflip.lol
PUBLIC_SCAN_DNS_DOMAIN=scan.privacy.whattheflip.lol

# Hostname in the scanner-ja4 self-signed cert (must match SNI used by clients).
PUBLIC_SCAN_JA4_HOST=ja4.scan.privacy.whattheflip.lol
