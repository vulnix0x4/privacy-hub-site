# Copy to .env and adjust.

# Web server port (what your upstream Caddy reverse-proxies to)
WEB_PORT=8421

# Scanner backend (Phase 3+)
JA4_PORT=8443
DNS_PORT=5353

# Public URLs for the scanner to reference
SCAN_JA4_URL=https://ja4.scan.privacy.whattheflip.lol
SCAN_DNS_DOMAIN=scan.privacy.whattheflip.lol
