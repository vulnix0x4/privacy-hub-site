{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "privacy-hub",
  "compatibility_date": "2026-04-01",
  "compatibility_flags": ["nodejs_compat"],
  "observability": {
    "enabled": false
  },
  "assets": {
    "directory": "./dist",
    "binding": "ASSETS",
    "run_worker_first": false
  }
}
